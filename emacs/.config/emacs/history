;; -*- mode: emacs-lisp; coding: utf-8-unix -*-
;; Minibuffer history file, automatically generated by ‘savehist’.

(setq savehist-minibuffer-history-variables '(buffer-name-history read-number-history grep-find-history minibuffer-history extended-command-history file-name-history))
(setq buffer-name-history '("init.el"))
(setq grep-find-history '("find . -type f -exec grep --color=auto -nH --null -e grep \\{\\} +"))
(setq minibuffer-history '("vertico-resize"))
(setq extended-command-history '("grep-find" "vertico-mode"))
(setq file-name-history '("~/dotfiles/.gitignore" "~/.config/emacs/init.el" "~/.config/emacs/" "~/.config/emacs/init.el"))
