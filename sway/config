# gnix0's sway config

output eDP-1 resolution 1366x768@60Hz position 0,0
output HDMI-A-1 resolution 2560x1440@60Hz position 1366,0

# Wallpaper
output * background /home/gnix0/Downloads/smoking.jpg fill

### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term alacritty
set $menu rofi -show drun
set $browser brave
set $fileManager thunar

### Appearance
default_border none
default_floating_border none
gaps inner 0
gaps outer 0
font pango:JetBrainsMono Nerd Font 10

### Input
input type:touchpad {
    dwt enabled
    tap enabled
    natural_scroll disabled
}

input type:keyboard {
    xkb_layout "us"
}

### Autostart
exec mako
exec nm-applet --indicator

# Cursor
seat * hide_cursor 2000

### Keybindings — Basics
bindsym $mod+Return exec $term
bindsym $mod+q kill
bindsym $mod+d exec $menu
bindsym $mod+t exec $fileManager
bindsym $mod+b exec $browser
bindsym $mod+f fullscreen
bindsym $mod+w exec pkill -USR1 waybar
bindsym $mod+p exec grimshot save area
floating_modifier $mod normal
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit sway?' -B 'Yes' 'swaymsg exit'

### Focus (vim keys)
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

### Move windows (vim keys)
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

### Workspaces
bindsym $mod+Control+a workspace number 1
bindsym $mod+Control+s workspace number 2
bindsym $mod+Control+d workspace number 3
bindsym $mod+Control+f workspace number 4
bindsym $mod+Control+g workspace number 5
bindsym $mod+Control+h workspace number 6
bindsym $mod+Control+j workspace number 7
bindsym $mod+Control+k workspace number 8
bindsym $mod+Control+l workspace number 9
bindsym $mod+Control+semicolon workspace number 10
bindsym $mod+Control+Shift+a move container to workspace number 1
bindsym $mod+Control+Shift+s move container to workspace number 2
bindsym $mod+Control+Shift+d move container to workspace number 3
bindsym $mod+Control+Shift+f move container to workspace number 4
bindsym $mod+Control+Shift+g move container to workspace number 5
bindsym $mod+Control+Shift+h move container to workspace number 6
bindsym $mod+Control+Shift+j move container to workspace number 7
bindsym $mod+Control+Shift+k move container to workspace number 8
bindsym $mod+Control+Shift+l move container to workspace number 9
bindsym $mod+Control+Shift+semicolon move container to workspace number 10

### Layout
bindsym $mod+v splitv
bindsym $mod+Shift+v splith
bindsym $mod+s layout stacking
bindsym $mod+Alt_L layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent
bindsym $mod+e exec emacs

### Scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

### Resize mode
mode "resize" {
    bindsym $left resize shrink width 20px
    bindsym $down resize grow height 20px
    bindsym $up resize shrink height 20px
    bindsym $right resize grow width 20px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

### Media / brightness keys
bindsym --locked XF86AudioRaiseVolume exec wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindsym --locked XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym --locked XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-

### Status bar
bar {
    swaybar_command waybar
    mode invisible
}

include /etc/sway/config.d/*
